# Development Environment
DJANGO_ENV=development
DJANGO_SECRET_KEY=dev-secret-key-not-for-production-use-only
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Redis (optional for dev - falls back to memory)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Weather API (get free key from openweathermap.org)
OPENWEATHERMAP_API_KEY=demo
WEATHER_API_BASE_URL=https://api.openweathermap.org/data/2.5

# PostgreSQL Database Configuration
DB_ENGINE=django.db.backends.postgresql
DB_NAME=weather_db
DB_USER=postgres
DB_PASSWORD=Hemant@123
DB_HOST=127.0.0.1
DB_PORT=5432
